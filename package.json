{
  "name": "campus-command",
  "productName": "Campus Command",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "npm run dist && open 'dist/mac-arm64/Campus Command.app'",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "marked": "^12.0.0",
    "mermaid": "^11.4.1",
    "plotly.js-dist-min": "^2.35.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "build": {
    "appId": "com.campuscommand.app",
    "productName": "Campus Command",
    "mac": {
      "category": "public.app-category.education"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "server.py",
      "agents/**/*",
      "tools/**/*",
      "memory/**/*",
      "config.py",
      "requirements.txt",
      ".env"
    ]
  }
}
